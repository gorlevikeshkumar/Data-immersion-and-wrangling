    "\n",
    "\n",
    "# Import libraries\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# Read CSV file\n",
    "df = pd.read_csv(r\"C:\\Users\\DELL\\Downloads\\sales_data.csv\")\n",
    "\n",
    "# Display first 10 rows\n",
    "print(\"FIRST 10 RECORDS\")\n",
    "print(df.head())\n",
    "\n",
    "\n",
    "print(\"\\nDATA INFORMATION\")\n",
    "print(df.info())\n",
    "\n",
    "print(\"\\nCOLUMN NAMES\")\n",
    "print(df.columns)\n",
    "\n",
    "# STEP 3 : CHECK MISSING VALUES\n",
    "\n",
    "print(\"\\nMISSING VALUES\")\n",
    "print(df.isnull().sum())\n",
    "\n",
    "# Fill missing numerical values with mean\n",
    "df[\"Age\"] = df[\"Age\"].fillna(df[\"Age\"].mean())\n",
    "\n",
    "# Fill missing categorical values\n",
    "df[\"City\"] = df[\"City\"].fillna(\"Unknown\")\n",
    "\n",
    "# STEP 4 : REMOVE DUPLICATES\n",
    "\n",
    "print(\"\\nDUPLICATE ROWS :\", df.duplicated().sum())\n",
    "\n",
    "df = df.drop_duplicates()\n",
    "\n",
    "# STEP 5 : STANDARDIZE DATA\n",
    "\n",
    "# Convert date column\n",
    "df[\"Order_Date\"] = pd.to_datetime(df[\"Order_Date\"])\n",
    "\n",
    "# Convert text into proper format\n",
    "df[\"Customer_Name\"] = df[\"Customer_Name\"].str.title()\n",
    "\n",
    "# STEP 6 : FEATURE ENGINEERING\n",
    "\n",
    "# Create Total Price column\n",
    "df[\"Total_Price\"] = df[\"Quantity\"] * df[\"Price\"]\n",
    "\n",
    "# Create Age Category\n",
    "df[\"Age_Group\"] = np.where(df[\"Age\"] < 30, \"Young\", \"Adult\")\n",
    "\n",
    "# STEP 7 : OUTLIER DETECTION\n",
    "\n",
    "Q1 = df[\"Price\"].quantile(0.25)\n",
    "Q3 = df[\"Price\"].quantile(0.75)\n",
    "\n",
    "IQR = Q3 - Q1\n",
    "\n",
    "lower = Q1 - 1.5 * IQR\n",
    "upper = Q3 + 1.5 * IQR\n",
    "\n",
    "outliers = df[(df[\"Price\"] < lower) | (df[\"Price\"] > upper)]\n",
    "\n",
    "print(\"\\nOUTLIERS\")\n",
    "print(outliers)\n",
    "\n",
    "# STEP 8 : SAVE CLEANED DATA\n",
    "\n",
    "df.to_csv(\"cleaned_sales_data.csv\", index=False)\n",
    "\n",
    "print(\"\\nDATA CLEANING COMPLETED\")\n",
    "print(\"Cleaned file saved as cleaned_sales_data.csv\")"
   ]
